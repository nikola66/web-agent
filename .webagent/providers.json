[
  {
    "id": "custom",
    "name": "Custom (OpenAI-compatible)",
    "kind": "openai",
    "requiresUserApiKey": true,
    "model": "gpt-4o-mini",
    "apiKey": {
      "settingKey": "custom",
      "envVar": "CUSTOM_API_KEY",
      "placeholder": "https://api.example.com/v1"
    },
    "runtime": {
      "customBaseUrlEnvVar": "CUSTOM_BASE_URL",
      "ensureV1Suffix": true
    }
  },
  {
    "id": "ollama",
    "name": "Ollama (cloud)",
    "order": 2,
    "kind": "openai",
    "requiresUserApiKey": true,
    "model": "gemma4:31b-cloud",
    "apiKey": {
      "settingKey": "ollama",
      "envVar": "OLLAMA_API_KEY",
      "placeholder": "Ollama API key",
      "getKeyUrl": "https://ollama.com/settings/keys"
    },
    "runtime": {
      "basePath": "ollama",
      "fallbackBaseUrl": "https://ollama.com/v1"
    }
  },
  {
    "id": "openrouter",
    "name": "OpenRouter",
    "isDefault": true,
    "order": 1,
    "kind": "openai",
    "requiresUserApiKey": true,
    "model": "google/gemma-4-26b-a4b-it",
    "apiKey": {
      "settingKey": "openrouter",
      "envVar": "OPENROUTER_API_KEY",
      "placeholder": "sk-or-...",
      "getKeyUrl": "https://openrouter.ai/keys"
    },
    "runtime": {
      "basePath": "openrouter",
      "fallbackBaseUrl": "https://openrouter.ai/api/v1",
      "extraHeaders": {
        "HTTP-Referer": "https://github.com/aratech/web-agent",
        "X-Title": "Web Agent"
      }
    }
  }
]