APP_URL=http://localhost:5173
APP_NAME=Web-Agent
VITE_WEBAGENT_LAUNCH_MODE=transit_only_proxy
VITE_WEBAGENT_DEBUG_LOG=0
VITE_WEBAGENT_DEBUG_LOG_DIR=debug-logs
WEBAGENT_DEBUG_PROXY=0
# Optional on the host when using Caddy reverse_proxy to the JSON sidecar (see railpack.json):
# WEBAGENT_CORS_PROXY_HOST=127.0.0.1
# WEBAGENT_CORS_PROXY_PORT=8799
# Used by `npm run test:browser` (loaded via playwright.config.ts from `.env` / `.env.local`)
TESTING_OPENROUTER_API_KEY=

# X API Credentials for Daily Posting Scheduler (OAuth 1.0a User Context)
# Get these from https://developer.twitter.com/ → Your App → Keys and Tokens
# See marketing/README.md for detailed setup instructions

# API Key from "API Key and Secret" section
X_API_KEY=

# API Secret Key from "API Key and Secret" section
X_API_SECRET=

# Access Token from "Authentication Tokens and Keys" section (click Generate if needed)
X_ACCESS_TOKEN=

# Access Token Secret from "Authentication Tokens and Keys" section
X_ACCESS_TOKEN_SECRET=

# Posting Configuration
# Set to "true" to post to X for real (default: false for safety)
LIVE_POSTING=false

# Set to "false" to post any status (default: true to only post approved items)
REQUIRE_APPROVAL=true

# Set to "false" to exclude GitHub/demo links from posts (default: true)
POST_INCLUDE_LINKS=true
