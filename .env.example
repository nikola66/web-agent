APP_URL=http://localhost:5173
APP_NAME=Web-Agent
VITE_WEBAGENT_LAUNCH_MODE=transit_only_proxy
VITE_WEBAGENT_DEBUG_LOG=0
VITE_WEBAGENT_DEBUG_LOG_DIR=debug-logs
WEBAGENT_DEBUG_PROXY=0

# Turn-state judge (bundled ONNX in models/turn-judge/ — see docs/turn-judge.md)
# Started with npm run dev and production scripts/start-with-proxy.sh
# Browser agent uses same-origin /api/turn-judge (Vite/Caddy proxy). Node-only direct URL:
# TURN_JUDGE_URL=http://127.0.0.1:8787/judge
TURN_JUDGE_PORT=8787
# WEBAGENT_TURN_JUDGE_HOST=127.0.0.1
# WEBAGENT_TURN_JUDGE=0
# WEBAGENT_TURN_JUDGE_SHADOW=1
# Optional retrain: edit data/turn-judge/*.jsonl then npm run judge:train (requires .venv-turn-judge)

# Host CORS/LLM proxy when using Caddy reverse_proxy (see railpack.json):
# WEBAGENT_CORS_PROXY_HOST=127.0.0.1
# WEBAGENT_CORS_PROXY_PORT=8799

# Used by `npm run test:browser` (loaded via playwright.config.ts from `.env` / `.env.local`)
TESTING_OPENROUTER_API_KEY=
