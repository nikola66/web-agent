# Copy to `.env.local` for local dev (gitignored). Suggested dev overrides: DEBUG_LOG=1, LAUNCH_MODE=standard.
APP_URL=http://localhost:5173
APP_NAME=Web-Agent
VITE_WEBAGENT_LAUNCH_MODE=transit_only_proxy
VITE_WEBAGENT_DEBUG_LOG=0
VITE_WEBAGENT_DEBUG_LOG_DIR=debug-logs
WEBAGENT_DEBUG_PROXY=0

# Loop Guard — local MobileBERT MNLI classifier (browser) decides continue / stop / ask_user after each step.
# Model weights are vendored under public/models/loop-guard/ (refresh: npm run download:loop-guard-model).
# Set VITE_WEBAGENT_LOOP_GUARD=0 to disable (runtime defaults to stop without nudges).
VITE_WEBAGENT_LOOP_GUARD=1
# Max recovery nudges per user turn when Loop Guard says continue (research prompts use the higher cap).
VITE_WEBAGENT_MAX_AUTO_CONTINUE_NUDGES=20
VITE_WEBAGENT_RESEARCH_MAX_AUTO_CONTINUE_NUDGES=30
# NLI thresholds (entailment scores 0–1; first match wins: stop → ask_user → continue → fallback stop).
VITE_WEBAGENT_LOOP_GUARD_MAX_MESSAGES=6
VITE_WEBAGENT_LOOP_GUARD_STOP_THRESHOLD=0.62
VITE_WEBAGENT_LOOP_GUARD_ASK_USER_THRESHOLD=0.60
VITE_WEBAGENT_LOOP_GUARD_CONTINUE_THRESHOLD=0.58

# Optional on the host when using Caddy reverse_proxy to the JSON sidecar (see railpack.json):
# WEBAGENT_CORS_PROXY_HOST=127.0.0.1
# WEBAGENT_CORS_PROXY_PORT=8799
# Used by `npm run test:browser` (loaded via playwright.config.ts from `.env` / `.env.local`)
TESTING_OPENROUTER_API_KEY=
